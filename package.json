{
  "name": "agentfactory",
  "private": true,
  "type": "module",
  "workspaces": ["packages/core", "packages/mcp", "packages/web", "packages/dispatcher", "packages/reviewer", "packages/watcher"],
  "engines": { "node": ">=26" },
  "scripts": {
    "build": "tsc -b && npm -w packages/web run build:client",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "node packages/mcp/dist/index.js",
    "mcp:dev": "tsx packages/mcp/src/index.ts",
    "web": "node packages/web/server/dist/index.js",
    "web:dev": "npm -w packages/web run dev",
    "web:dev:server": "tsx packages/web/server/index.ts",
    "dispatcher": "node packages/dispatcher/dist/index.js",
    "dispatcher:dev": "tsx packages/dispatcher/src/index.ts",
    "reviewer": "node packages/reviewer/dist/index.js",
    "reviewer:dev": "tsx packages/reviewer/src/index.ts",
    "watcher": "node packages/watcher/dist/index.js",
    "watcher:dev": "tsx packages/watcher/src/index.ts",
    "supervisors": "concurrently -n disp,rev,watch -c blue,magenta,green \"node packages/dispatcher/dist/index.js dispatcher.config.json\" \"node packages/reviewer/dist/index.js reviewer.config.json\" \"node packages/watcher/dist/index.js watcher.config.json\"",
    "supervisors:dev": "concurrently -n disp,rev,watch -c blue,magenta,green \"npm:dispatcher:dev -- dispatcher.config.json\" \"npm:reviewer:dev -- reviewer.config.json\" \"npm:watcher:dev -- watcher.config.json\"",
    "token": "tsx packages/web/server/mintToken.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0",
    "@types/node": "^24.0.0",
    "concurrently": "^10.0.3"
  }
}
